generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Person {
  id                 String          @id @default(cuid())
  name               String          @unique
  active             Boolean         @default(true)
  canLogin           Boolean         @default(false)
  passwordHash       String?
  mustChangePassword Boolean         @default(true)
  isAdmin            Boolean         @default(false)
  isDemo             Boolean         @default(false)
  createdAt          DateTime        @default(now())
  ownedProjects      Project[]       @relation("ProjectOwner")
  createdProjects    Project[]       @relation("ProjectCreatedBy")
  updatedProjects    Project[]       @relation("ProjectUpdatedBy")
  projectMemberships ProjectMember[]
  updatedMilestones  Milestone[]     @relation("MilestoneUpdatedBy")
  assignedMilestones Milestone[]     @relation("MilestoneAssignee")
  weeklyUpdates      WeeklyUpdate[]
  ideas              Idea[]
}

model Project {
  id             String          @id @default(cuid())
  name           String
  client         String
  category       String
  status         String          @default("planning")
  priority       String          @default("medium")
  isDemo         Boolean         @default(false)
  ownerId        String
  owner          Person          @relation("ProjectOwner", fields: [ownerId], references: [id])
  progress       Int
  budget         Float?
  completed      Boolean         @default(false)
  archived       Boolean         @default(false)
  startDate      DateTime
  endDate        DateTime
  sharePointLink String?
  notes          String?
  version        Int             @default(1)
  createdAt      DateTime        @default(now())
  createdById    String
  createdBy      Person          @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  updatedAt      DateTime        @updatedAt
  updatedById    String
  updatedBy      Person          @relation("ProjectUpdatedBy", fields: [updatedById], references: [id])
  members        ProjectMember[]
  milestones     Milestone[]
  flags          Flag[]
  weeklyUpdates  WeeklyUpdate[]

  @@index([ownerId])
  @@index([endDate])
  @@index([completed])
  @@index([archived])
}

model ProjectMember {
  projectId String
  personId  String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([projectId, personId])
  @@index([personId])
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime
  // Kept temporarily so existing route/component code can compile while the
  // UI migrates from point-in-time deliverables to milestone date ranges.
  dueDate     DateTime
  done        Boolean  @default(false)
  assigneeId  String
  assignee    Person   @relation("MilestoneAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   Person?  @relation("MilestoneUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([updatedById])
  @@index([assigneeId])
}

model Flag {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  needs     String
  from      String
  raised    DateTime
  status    String   @default("open")
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

model WeeklyUpdate {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId       String
  owner         Person   @relation(fields: [ownerId], references: [id])
  weekOf        DateTime
  summary       String
  priorities    String
  rawTranscript String?
  createdDate   DateTime @default(now())
  version       Int      @default(1)

  @@unique([projectId, ownerId, weekOf])
  @@index([projectId, weekOf])
  @@index([ownerId, weekOf])
}

model Idea {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  author    Person   @relation(fields: [authorId], references: [id])
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([authorId])
}
