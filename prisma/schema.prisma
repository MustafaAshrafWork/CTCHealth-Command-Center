generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Person {
  id                 String          @id @default(cuid())
  name               String          @unique
  active             Boolean         @default(true)
  canLogin           Boolean         @default(false)
  passwordHash       String?
  mustChangePassword Boolean         @default(true)
  isAdmin            Boolean         @default(false)
  createdAt          DateTime        @default(now())
  ownedProjects      Project[]       @relation("ProjectOwner")
  createdProjects    Project[]       @relation("ProjectCreatedBy")
  updatedProjects    Project[]       @relation("ProjectUpdatedBy")
  projectMemberships ProjectMember[]
  updatedMilestones  Milestone[]     @relation("MilestoneUpdatedBy")
  assignedMilestones Milestone[]     @relation("MilestoneAssignee")
  ideas              Idea[]
}

model Project {
  id          String          @id @default(cuid())
  name        String
  client      String
  category    String
  status      String          @default("planning")
  priority    String          @default("medium")
  ownerId     String
  owner       Person          @relation("ProjectOwner", fields: [ownerId], references: [id])
  progress    Int
  archived    Boolean         @default(false)
  startDate   DateTime
  endDate     DateTime
  notes       String?
  version     Int             @default(1)
  createdAt   DateTime        @default(now())
  createdById String
  createdBy   Person          @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  updatedAt   DateTime        @updatedAt
  updatedById String
  updatedBy   Person          @relation("ProjectUpdatedBy", fields: [updatedById], references: [id])
  members     ProjectMember[]
  milestones  Milestone[]

  @@index([ownerId])
  @@index([endDate])
  @@index([archived])
}

model ProjectMember {
  projectId String
  personId  String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([projectId, personId])
  @@index([personId])
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  dueDate     DateTime
  done        Boolean  @default(false)
  assigneeId  String?
  assignee    Person?  @relation("MilestoneAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   Person?  @relation("MilestoneUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([updatedById])
  @@index([assigneeId])
}

model Idea {
  id        String   @id @default(cuid())
  text      String
  authorId  String
  author    Person   @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@index([authorId])
}
